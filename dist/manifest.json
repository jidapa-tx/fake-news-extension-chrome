{
  "manifest_version": 3,
  "name": "ชัวร์ก่อนแชร์",
  "short_name": "ชัวร์ก่อนแชร์",
  "version": "0.1.0",
  "description": "ตรวจสอบข่าวก่อนส่งต่อ เพราะข่าวปลอมแพร่เร็วกว่าที่คุณคิด",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "ชัวร์ก่อนแชร์"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-cIoNO6AA.js"
      ],
      "matches": [
        "*://*.facebook.com/*",
        "*://*.x.com/*",
        "*://*.twitter.com/*",
        "*://today.line.me/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.facebook.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://today.line.me/*"
      ],
      "resources": [
        "assets/index.ts-cIoNO6AA.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
